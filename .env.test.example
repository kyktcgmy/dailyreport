# テスト用環境変数
# このファイルをコピーして .env.test を作成してください
# cp .env.test.example .env.test

# テスト用DB（docker-compose の db_test サービス: port 5433）
DATABASE_URL="postgresql://user:password@localhost:5433/dailyreport_test?schema=public"

# JWT
JWT_SECRET="test-secret-key"
JWT_EXPIRES_IN="1h"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
